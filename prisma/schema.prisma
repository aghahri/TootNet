// Toot - Social Messaging Platform
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

enum NetworkMemberRole {
  NETWORK_ADMIN
  MEMBER
}

enum GroupMemberRole {
  GROUP_ADMIN
  MEMBER
}

enum ChannelMemberRole {
  CHANNEL_ADMIN
  SUBSCRIBER
}

enum NetworkVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum MediaType {
  IMAGE
  VIDEO
  FILE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  mobile       String?
  passwordHash String   @map("password_hash")
  name         String
  avatar       String?
  bio          String?  @db.Text
  globalRole   GlobalRole @default(USER) @map("global_role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens   RefreshToken[]
  networkMembers  NetworkMember[]
  groupMembers    GroupMember[]
  channelMembers  ChannelMember[]
  groupMessages   GroupMessage[]
  channelMessages ChannelMessage[]
  messageReports  MessageReport[]
  notifications   Notification[]
  networksCreated Network[]       @relation("NetworkCreator")
  groupsCreated   Group[]         @relation("GroupCreator")
  channelsCreated Channel[]      @relation("ChannelCreator")
  media           Media[]
  groupMessageReactions   GroupMessageReaction[]
  channelMessageReactions ChannelMessageReaction[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  hashedToken String   @map("hashed_token")
  userId      String   @map("user_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}


model Network {
  id          String            @id @default(cuid())
  name        String
  description String?           @db.Text
  slug        String?           @unique
  visibility  NetworkVisibility @default(PUBLIC)
  isFeatured  Boolean           @default(false) @map("is_featured")
  createdById String            @map("created_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  creator      User            @relation("NetworkCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      NetworkMember[]
  groups       Group[]
  channels     Channel[]
  announcements Announcement[]

  @@index([visibility])
  @@index([isFeatured])
  @@map("networks")
}


model NetworkMember {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  networkId   String            @map("network_id")
  role        NetworkMemberRole @default(MEMBER)
  joinedAt    DateTime          @default(now()) @map("joined_at")
  suspendedAt DateTime?         @map("suspended_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([userId, networkId])
  @@index([networkId])
  @@index([suspendedAt])
  @@map("network_members")
}

model Group {
  id          String   @id @default(cuid())
  networkId   String   @map("network_id")
  name        String
  description String?  @db.Text
  isFeatured  Boolean  @default(false) @map("is_featured")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  network  Network        @relation(fields: [networkId], references: [id], onDelete: Cascade)
  creator  User           @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members  GroupMember[]
  messages GroupMessage[]

  @@index([networkId])
  @@index([createdAt])
  @@index([isFeatured])
  @@map("groups")
}

model GroupMember {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  groupId   String          @map("group_id")
  role      GroupMemberRole @default(MEMBER)
  joinedAt  DateTime        @default(now()) @map("joined_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("group_members")
}

model GroupMessage {
  id               String    @id @default(cuid())
  groupId          String    @map("group_id")
  senderId         String    @map("sender_id")
  content          String    @db.Text
  mediaId          String?   @map("media_id")
  replyToMessageId String?   @map("reply_to_message_id")
  isEdited         Boolean   @default(false) @map("is_edited")
  deletedAt        DateTime? @map("deleted_at")
  deletedByUserId  String?   @map("deleted_by_user_id") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at")

  group    Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender   User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
  media    Media?             @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  replyToMessage GroupMessage? @relation("GroupMessageReplyTo", fields: [replyToMessageId], references: [id])
  replies       GroupMessage[] @relation("GroupMessageReplyTo")
  reports  MessageReport[]
  editHistory GroupMessageEdit[]
  reactions GroupMessageReaction[]

  @@index([groupId, createdAt])
  @@index([mediaId])
  @@index([deletedAt])
  @@index([replyToMessageId])
  @@map("group_messages")
}

model GroupMessageEdit {
  id             String   @id @default(cuid())
  messageId      String   @map("message_id")
  previousContent String  @map("previous_content") @db.Text
  editedAt       DateTime @default(now()) @map("edited_at")
  editedByUserId String   @map("edited_by_user_id") @db.VarChar(64)

  message GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("group_message_edits")
}

model Channel {
  id          String   @id @default(cuid())
  networkId   String   @map("network_id")
  name        String
  description String?  @db.Text
  isFeatured  Boolean  @default(false) @map("is_featured")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  network  Network         @relation(fields: [networkId], references: [id], onDelete: Cascade)
  creator  User            @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members  ChannelMember[]
  messages ChannelMessage[]

  @@index([networkId])
  @@index([createdAt])
  @@index([isFeatured])
  @@map("channels")
}

model ChannelMember {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  channelId String            @map("channel_id")
  role      ChannelMemberRole @default(SUBSCRIBER)
  joinedAt  DateTime          @default(now()) @map("joined_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
  @@map("channel_members")
}

model ChannelMessage {
  id               String    @id @default(cuid())
  channelId        String    @map("channel_id")
  senderId         String    @map("sender_id")
  content          String    @db.Text
  mediaId          String?   @map("media_id")
  replyToMessageId String?   @map("reply_to_message_id")
  isEdited         Boolean   @default(false) @map("is_edited")
  deletedAt        DateTime? @map("deleted_at")
  deletedByUserId  String?   @map("deleted_by_user_id") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at")

  channel    Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender     User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  media      Media?              @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  replyToMessage ChannelMessage? @relation("ChannelMessageReplyTo", fields: [replyToMessageId], references: [id])
  replies       ChannelMessage[] @relation("ChannelMessageReplyTo")
  reports    MessageReport[]
  editHistory ChannelMessageEdit[]
  reactions ChannelMessageReaction[]

  @@index([channelId, createdAt])
  @@index([mediaId])
  @@index([deletedAt])
  @@index([replyToMessageId])
  @@map("channel_messages")
}

model ChannelMessageEdit {
  id             String   @id @default(cuid())
  messageId      String   @map("message_id")
  previousContent String  @map("previous_content") @db.Text
  editedAt       DateTime @default(now()) @map("edited_at")
  editedByUserId String   @map("edited_by_user_id") @db.VarChar(64)

  message ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("channel_message_edits")
}

model GroupMessageReaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String   @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  message GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@map("group_message_reactions")
}

model ChannelMessageReaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String   @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  message ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@map("channel_message_reactions")
}

enum MessageReportType {
  GROUP
  CHANNEL
}

model MessageReport {
  id             String           @id @default(cuid())
  reporterId     String           @map("reporter_id")
  messageType    MessageReportType @map("message_type")
  groupMessageId String?          @map("group_message_id")
  channelMessageId String?        @map("channel_message_id")
  reason         String           @db.VarChar(100)
  description    String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")

  reporter User  @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  groupMessage   GroupMessage?    @relation(fields: [groupMessageId], references: [id], onDelete: Cascade)
  channelMessage ChannelMessage? @relation(fields: [channelMessageId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([groupMessageId])
  @@index([channelMessageId])
  @@index([createdAt])
  @@map("message_reports")
}

enum AnnouncementScopeType {
  GLOBAL
  NETWORK
}

model Announcement {
  id          String                @id @default(cuid())
  title       String                @db.VarChar(200)
  body        String                @db.Text
  scopeType   AnnouncementScopeType @map("scope_type")
  networkId   String?               @map("network_id")
  isPublished Boolean              @default(false) @map("is_published")
  publishedAt DateTime?             @map("published_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  network Network? @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([scopeType])
  @@index([networkId])
  @@index([isPublished, publishedAt])
  @@map("announcements")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String    @map("type") @db.VarChar(50)
  title     String    @db.VarChar(200)
  body      String?   @db.Text
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@map("notifications")
}

// Audit log: immutable trail for important actions. No FK to User so entries survive user deletion.
model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String   @map("actor_user_id") @db.VarChar(64)
  action        String   @db.VarChar(64)
  resourceType  String   @map("resource_type") @db.VarChar(32)
  resourceId    String?  @map("resource_id")   @db.VarChar(64)
  metadata      Json?    @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Media {
  id           String    @id @default(cuid())
  type         MediaType
  url          String    @db.VarChar(1024)
  size         Int       @default(0)
  mimeType     String    @map("mime_type") @db.VarChar(128)
  originalName  String?   @map("original_name") @db.VarChar(512)
  uploaderId   String    @map("uploader_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  uploader         User             @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  groupMessages    GroupMessage[]
  channelMessages  ChannelMessage[]

  @@index([uploaderId])
  @@index([type])
  @@map("media")
}

model Post {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  text      String   @db.Text
  mediaUrl  String?  @map("media_url") @db.VarChar(1024)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("posts")
}
